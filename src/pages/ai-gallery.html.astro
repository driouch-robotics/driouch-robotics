---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'معرض الفيديوهات بالذكاء الاصطناعي',
};
---

<Layout metadata={metadata}>
  <main class="min-h-[70vh] bg-slate-50 dark:bg-slate-950 py-16 md:py-24" dir="rtl">
    <section class="container mx-auto px-4 sm:px-6 max-w-3xl text-center">
      <span class="text-[#20A4F3] font-extrabold text-lg">صناعة المحتوى بالذكاء الاصطناعي</span>
      <h1 class="mt-3 text-3xl md:text-5xl font-black text-slate-900 dark:text-white">
        معرض الإنجازات سيضاف قريبًا
      </h1>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
        هذه الصفحة جاهزة كمسار نشر، ويمكننا لاحقًا إضافة الفيديوهات والصور وروابط الأعمال النهائية
        داخلها.
      </p>

      <div class="mt-8">
        <a
          href="./projects/ai-content-creation"
          class="inline-flex items-center justify-center rounded-xl bg-[#20A4F3] px-6 py-3 font-black text-[#0B1C4B] hover:bg-[#0B1C4B] hover:text-white transition-colors"
        >
          الرجوع إلى تفاصيل المشروع
        </a>
      </div>
    </section>
  </main>
</Layout>
