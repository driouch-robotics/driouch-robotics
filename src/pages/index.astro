---
import projectsData from '~/data/projects.json';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getAsset, getPermalink } from '~/utils/permalinks';

import schoolLogo from '~/assets/images/school-logo.png';
import kartFutureLogo from '~/assets/images/kart-future-logo.png';
// import provinceLogo from '~/assets/images/province-logo.png';

import teamData from '~/data/team.json';

const metadata = {
  title: 'IA & Robotics Club - Driouch',
  ignoreTitleTemplate: true,
};

const clubLocationQuery = encodeURIComponent(
  'ثانوية الوحدة الإعدادية الرائدة جماعة امطالسة مديرية الدريوش جهة الشرق المغرب'
);

const mapsEmbedUrl = `https://www.google.com/maps?q=${clubLocationQuery}&output=embed`;
const mapsDirectionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${clubLocationQuery}`;
const mapsSearchUrl = `https://www.google.com/maps/search/?api=1&query=${clubLocationQuery}`;

const contactPhone = '+212677035415';
const contactPhoneDisplay = '+212 677 035 415';
const contactEmail = 'mohamed.elrhaouat@gmail.com';

const institutionPhone = '0666364033';
const institutionPhoneDisplay = '0666 364 033';
const institutionEmail = 'najimammari794@gmail.com';
const principalPhone = '0602651223';
const principalPhoneDisplay = '0602 651 223';

const projectImageModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/*', {
  eager: true,
});

const resolveProjectImage = (imagePath = '') =>
  projectImageModules[`/${imagePath.replace(/^\//, '')}`]?.default;

const isExternalUrl = (href = '') => href.startsWith('http://') || href.startsWith('https://');
const resolveSiteHref = (href = '') =>
  isExternalUrl(href) || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('#')
    ? href
    : getPermalink(href);
---

<Layout metadata={metadata}>
  <style is:global>
    .animated-gradient-text {
      background: linear-gradient(to right, #20A4F3, #0B1C4B, #20A4F3, #00d2ff);
      background-size: 200% auto;
      color: transparent;
      -webkit-background-clip: text;
      background-clip: text;
      animation: shine 4s linear infinite;
    }

    @keyframes shine {
      to {
        background-position: 200% center;
      }
    }

    @keyframes neural-glow {
      0%,
      100% {
        opacity: 0.15;
        filter: brightness(1) drop-shadow(0 0 2px rgba(32, 164, 243, 0.1));
        transform: scale(1);
      }

      50% {
        opacity: 0.4;
        filter: brightness(1.2) drop-shadow(0 0 8px rgba(32, 164, 243, 0.4));
        transform: scale(1.01);
      }
    }

    .animate-neural-glow {
      animation: neural-glow 6s ease-in-out infinite;
    }

    .club-accordion details {
      overflow: hidden;
      scroll-margin-top: 110px;
    }

    .club-accordion summary::-webkit-details-marker {
      display: none;
    }

    .club-accordion details[open] summary .accordion-plus {
      transform: rotate(45deg);
    }

    .club-map-frame {
      min-height: 420px;
    }

    .institution-logo-trigger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.45rem 0.9rem;
      border-radius: 1.5rem;
      border: 1px solid transparent;
      background: transparent;
      transition:
        transform 0.3s ease,
        border-color 0.3s ease,
        background-color 0.3s ease,
        box-shadow 0.3s ease;
    }

    .institution-logo-trigger:hover {
      transform: translateY(-2px);
      border-color: rgba(32, 164, 243, 0.22);
      background: rgba(255, 255, 255, 0.65);
      box-shadow: 0 18px 40px -28px rgba(11, 28, 75, 0.35);
    }

    .dark .institution-logo-trigger:hover {
      background: rgba(15, 23, 42, 0.35);
      border-color: rgba(32, 164, 243, 0.32);
    }

    .institution-dialog {
      width: min(96vw, 1220px);
      max-width: min(96vw, 1220px);
      max-height: 92vh;
      padding: 0;
      border: 0;
      background: transparent;
      overflow: visible;
    }

    .institution-dialog::backdrop {
      background: rgba(15, 23, 42, 0.58);
      backdrop-filter: blur(7px);
    }

    .institution-dialog-panel {
      animation: institution-pop 0.22s ease-out;
      max-height: 92vh;
      overflow: hidden;
    }

    .institution-dialog-body {
      padding: 1rem;
    }

    .institution-top-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 1rem;
      align-items: center;
    }

    .institution-title {
      font-size: 2.2rem;
      line-height: 1.15;
    }

    .institution-desc {
      font-size: 1rem;
      line-height: 1.8;
    }

    .institution-logo-box {
      min-height: 180px;
    }

    .institution-logo-box img,
    .institution-logo-box picture,
    .institution-logo-box :where(img) {
      max-height: 130px;
    }

    .institution-stat-card {
      min-height: 78px;
    }

    .institution-contact-card {
      min-height: 78px;
    }

    .institution-mini-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: flex-end;
      margin-top: 0.9rem;
    }

    @keyframes institution-pop {
      from {
        opacity: 0;
        transform: translateY(8px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (max-width: 1279px) {
      .institution-dialog {
        width: min(96vw, 1080px);
        max-width: min(96vw, 1080px);
      }

      .institution-title {
        font-size: 2rem;
      }

      .institution-desc {
        font-size: 0.96rem;
      }
    }

    @media (max-width: 1024px) {
      .institution-dialog {
        width: min(96vw, 860px);
        max-width: min(96vw, 860px);
      }

      .institution-dialog-panel {
        max-height: 90vh;
        overflow: auto;
      }

      .institution-top-grid {
        grid-template-columns: 1fr;
      }

      .institution-title {
        font-size: 1.8rem;
      }

      .institution-logo-box {
        min-height: 150px;
      }
    }

    @media (max-width: 768px) {
      .club-map-frame {
        min-height: 340px;
      }

      .institution-dialog {
        width: 96vw;
        max-width: 96vw;
      }

      .institution-dialog-panel {
        max-height: 90vh;
        overflow: auto;
      }

      .institution-dialog-body {
        padding: 0.9rem;
      }

      .institution-title {
        font-size: 1.55rem;
      }

      .institution-desc {
        font-size: 0.94rem;
        line-height: 1.75;
      }

      .institution-stat-card,
      .institution-contact-card {
        min-height: auto;
      }
    }
  </style>

  <Hero
    actions={[
      { variant: 'primary', text: 'اكتشف مشاريعنا', href: '#projects', icon: 'tabler:rocket' },
      { text: 'لائحة المهندسين', href: '#team', icon: 'tabler:users' },
    ]}
  >
    <Fragment slot="bg">
      <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
        <img
          src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
          alt="AI Background Light"
          class="absolute inset-0 w-full h-full object-cover opacity-20 block dark:hidden invert grayscale"
        />

        <img
          src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
          alt="Neural Network Glow"
          class="absolute inset-0 w-full h-full object-cover hidden dark:block mix-blend-screen animate-neural-glow"
        />

        <div class="absolute inset-0 bg-gradient-to-t from-white via-white/60 to-transparent dark:from-slate-900 dark:via-slate-900/80"></div>
      </div>
    </Fragment>

    <Fragment slot="title">
      <div class="flex flex-col gap-2 md:gap-3 mb-2 relative z-10 mt-[-1rem] md:mt-[-2rem]">
        <span class="text-gray-900 dark:text-white leading-tight text-3xl md:text-5xl">
          نادي الروبوتيك والذكاء الاصطناعي
        </span>
        <span class="animated-gradient-text text-4xl md:text-6xl font-extrabold tracking-wide">
          IA & Robotics Club
        </span>
      </div>
    </Fragment>

    <Fragment slot="subtitle">
      <p
        class="text-base md:text-lg text-gray-600 dark:text-gray-400 mb-4 leading-relaxed relative z-10"
        dir="rtl"
      >
        نحن جيل المستقبل! نبتكر حلولاً ذكية ومستدامة من خلال مشاريع رائدة تدمج بين التكنولوجيا
        المتقدمة والهوية المحلية.
      </p>

      <div
        class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-800 flex flex-col items-center justify-center gap-4 relative z-10"
      >
        <span class="text-base md:text-lg lg:text-xl text-[#20A4F3] dark:text-[#20A4F3] tracking-tight font-extrabold">
          تحت إشراف
        </span>

        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-12">
          <div class="flex flex-col items-center gap-3 group">
            <button
              type="button"
              class="institution-logo-trigger"
              aria-haspopup="dialog"
              aria-controls="institution-info-dialog"
              data-open-institution-dialog
            >
              <Image
                src={schoolLogo}
                alt="ثانوية الوحدة الإعدادية الرائدة"
                class="h-16 md:h-20 lg:h-24 xl:h-28 w-auto object-contain transition-all duration-300 ease-out group-hover:scale-110 group-hover:-translate-y-1 drop-shadow-md group-hover:drop-shadow-xl"
              />
            </button>

            
          </div>

          <!-- <div class="flex flex-col items-center gap-2 group">
            <img
              src="https://placehold.co/150x80/transparent/20A4F3?text=Driouch+Province+Logo"
              alt="عمالة إقليم الدريوش"
              class="h-12 md:h-16 w-auto object-contain transition-transform duration-300 group-hover:scale-110 drop-shadow-sm"
            />-->
          </div>
        </div>
      </div>
    </Fragment>
  </Hero>

  <dialog id="institution-info-dialog" class="institution-dialog rounded-[28px] text-right">
    <div
      class="institution-dialog-panel relative rounded-[28px] bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700 shadow-[0_30px_80px_-20px_rgba(15,23,42,0.45)]"
    >
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_right,rgba(32,164,243,0.14),transparent_26%),radial-gradient(circle_at_bottom_left,rgba(11,28,75,0.08),transparent_28%)]"></div>

      <button
        type="button"
        data-close-institution-dialog
        class="absolute top-4 left-4 z-20 inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-red-50 hover:text-red-500 dark:hover:bg-slate-700 transition-colors"
        aria-label="إغلاق"
      >
        ✕
      </button>

      <div class="institution-dialog-body relative">
        <div class="institution-top-grid">
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <span
                class="inline-flex w-fit items-center px-3 py-1 rounded-full bg-blue-50 dark:bg-slate-800 text-[#20A4F3] text-xs font-black border border-blue-100 dark:border-slate-700"
              >
                معلومات المؤسسة
              </span>

              <div class="hidden xl:flex items-center gap-2">
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-bold">
                  جماعة امطالسة
                </span>
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-bold">
                  إقليم الدريوش
                </span>
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-bold">
                  جهة الشرق
                </span>
              </div>
            </div>

            <h3 class="institution-title mt-3 font-extrabold text-gray-900 dark:text-white">
              ثانوية الوحدة الإعدادية الرائدة
            </h3>

            <p class="institution-desc mt-3 text-gray-600 dark:text-slate-400">
              مؤسسة تربوية تعليمية للتعليم العمومي، تأسست سنة 2023، وتقع بجماعة امطالسة التابعة
              لإقليم الدريوش بجهة الشرق، وتندرج ضمن المديرية الإقليمية للدريوش، ويشرف على إدارتها
              السيد نجيب العماري.
            </p>

            <div class="mt-3 flex flex-wrap items-center gap-2 xl:hidden">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs md:text-sm font-bold">
                جماعة امطالسة
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs md:text-sm font-bold">
                إقليم الدريوش
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs md:text-sm font-bold">
                جهة الشرق
              </span>
            </div>

            <div class="institution-mini-actions">
              <a
                href="#location"
                data-close-institution-dialog
                class="inline-flex items-center justify-center px-4 py-2 rounded-xl bg-[#20A4F3] text-[#0B1C4B] font-black hover:bg-[#0B1C4B] hover:text-white transition-colors text-sm"
              >
                الموقع الجغرافي
              </a>

              <button
                type="button"
                data-close-institution-dialog
                class="inline-flex items-center justify-center px-4 py-2 rounded-xl border border-gray-200 dark:border-slate-700 text-gray-900 dark:text-white font-bold hover:border-[#20A4F3] hover:text-[#20A4F3] transition-colors text-sm"
              >
                إغلاق
              </button>
            </div>
          </div>

          <div class="institution-logo-box rounded-[22px] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-950 shadow-sm p-4 flex items-center justify-center">
            <Image
              src={schoolLogo}
              alt="ثانوية الوحدة الإعدادية الرائدة"
              class="w-auto object-contain"
            />
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 lg:grid-cols-6 gap-3">
          <div class="institution-stat-card rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-3 flex flex-col justify-between">
            <span class="text-xs font-black text-[#20A4F3]">سنة التأسيس</span>
            <p class="mt-1 text-xl md:text-2xl font-extrabold text-gray-900 dark:text-white">2023</p>
          </div>

          <div class="institution-stat-card rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-3 flex flex-col justify-between">
            <span class="text-xs font-black text-[#20A4F3]">المدير</span>
            <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white">نجيب العماري</p>
          </div>

          <div class="institution-stat-card rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-3 flex flex-col justify-between">
            <span class="text-xs font-black text-[#20A4F3]">النوع</span>
            <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white">تعليم عمومي</p>
          </div>

          <div class="institution-stat-card rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-3 flex flex-col justify-between">
            <span class="text-xs font-black text-[#20A4F3]">الجماعة</span>
            <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white">امطالسة</p>
          </div>

          <div class="institution-stat-card rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-3 flex flex-col justify-between">
            <span class="text-xs font-black text-[#20A4F3]">الإقليم</span>
            <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white">الدريوش</p>
          </div>

          <div class="institution-stat-card rounded-2xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-3 flex flex-col justify-between">
            <span class="text-xs font-black text-[#20A4F3]">الجهة</span>
            <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white">الشرق</p>
          </div>
        </div>

        <div class="mt-4 rounded-3xl border border-gray-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-4">
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-2 mb-3">
            <div>
              <h4 class="text-lg md:text-xl font-extrabold text-gray-900 dark:text-white">
                معلومات التواصل
              </h4>
              <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">
                وسائل التواصل الخاصة بالمؤسسة وإدارة المؤسسة
              </p>
            </div>

            <div class="text-sm font-bold text-[#20A4F3]">
              المديرية الإقليمية للدريوش
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <a
              href={`tel:${institutionPhone}`}
              class="institution-contact-card rounded-2xl bg-white dark:bg-slate-900 border border-blue-100 dark:border-slate-700 p-3 hover:border-[#20A4F3] transition-colors"
            >
              <span class="text-xs font-black text-[#20A4F3]">رقم المؤسسة</span>
              <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white" dir="ltr">
                {institutionPhoneDisplay}
              </p>
            </a>

            <a
              href={`mailto:${institutionEmail}`}
              class="institution-contact-card rounded-2xl bg-white dark:bg-slate-900 border border-blue-100 dark:border-slate-700 p-3 hover:border-[#20A4F3] transition-colors"
            >
              <span class="text-xs font-black text-[#20A4F3]">البريد الإلكتروني</span>
              <p class="mt-1 text-sm md:text-base font-extrabold text-gray-900 dark:text-white break-all" dir="ltr">
                {institutionEmail}
              </p>
            </a>

            <a
              href={`tel:${principalPhone}`}
              class="institution-contact-card rounded-2xl bg-white dark:bg-slate-900 border border-blue-100 dark:border-slate-700 p-3 hover:border-[#20A4F3] transition-colors"
            >
              <span class="text-xs font-black text-[#20A4F3]">رقم المدير</span>
              <p class="mt-1 text-base md:text-lg font-extrabold text-gray-900 dark:text-white" dir="ltr">
                {principalPhoneDisplay}
              </p>
            </a>
          </div>
        </div>
      </div>
    </div>
  </dialog>

  <section
    class="py-12 bg-slate-50/50 dark:bg-slate-900/30 border-y border-gray-100 dark:border-slate-800 relative z-10"
  >
    <div class="container mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center" dir="rtl">
        <div
          class="flex flex-col items-center p-6 bg-white dark:bg-slate-800 rounded-2xl border-2 border-yellow-400/30 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-yellow-300 to-yellow-500"></div>
          <h3
            class="text-xl font-black text-yellow-600 dark:text-yellow-500 mb-1 uppercase tracking-wider font-sans"
            dir="ltr"
          >
            Gold Sponsors
          </h3>
          <span class="text-xs font-bold text-gray-400 dark:text-gray-500 mb-6">الرعاة الذهبيون</span>
          <div class="flex-grow flex flex-wrap items-center justify-center gap-4 w-full"></div>
        </div>

        <div
          class="flex flex-col items-center p-6 bg-white dark:bg-slate-800 rounded-2xl border border-slate-300 dark:border-slate-600 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-slate-300 to-slate-400"></div>
          <h3
            class="text-xl font-black text-slate-600 dark:text-slate-400 mb-1 uppercase tracking-wider font-sans"
            dir="ltr"
          >
            Silver Sponsors
          </h3>
          <span class="text-xs font-bold text-gray-400 dark:text-gray-500 mb-6">الرعاة الفضيون</span>
          <div class="flex-grow flex flex-wrap items-center justify-center gap-4 w-full"></div>
        </div>

        <div
          class="flex flex-col items-center p-6 bg-white dark:bg-slate-800 rounded-2xl border-2 border-[#20A4F3]/30 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#0B1C4B] to-[#20A4F3]"></div>
          <h3
            class="text-xl font-black text-[#20A4F3] mb-1 uppercase tracking-wider font-sans"
            dir="ltr"
          >
            Our Partners
          </h3>
          <span class="text-xs font-bold text-gray-400 dark:text-gray-500 mb-6">شركاء النجاح</span>

          <div class="flex-grow flex flex-col items-center justify-center gap-4 w-full">
            <div class="flex flex-col items-center gap-2 group">
              <Image
                src={kartFutureLogo}
                alt="جمعية كرت المستقبل"
                class="h-14 w-auto object-contain rounded-full shadow-sm group-hover:scale-110 transition-transform bg-white"
              />
              
            </div>

            <div class="flex flex-col items-center gap-2 mt-2 group"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    id="about"
