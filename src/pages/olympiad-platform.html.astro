---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'منصة أولمبياد المعرفة المعلوماتية',
};
---

<Layout metadata={metadata}>
  <main class="min-h-[70vh] bg-slate-50 dark:bg-slate-950 py-16 md:py-24" dir="rtl">
    <section class="container mx-auto px-4 sm:px-6 max-w-3xl text-center">
      <span class="text-[#20A4F3] font-extrabold text-lg">أولمبياد المعرفة</span>
      <h1 class="mt-3 text-3xl md:text-5xl font-black text-slate-900 dark:text-white">
        منصة الأولمبياد الرقمية
      </h1>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
        منصة الأولمبياد موجودة في مشروع مستقل حتى تبقى المسابقة قابلة للتطوير والتحديث بشكل منفصل عن
        موقع النادي.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
        <a
          href="https://driouch-robotics.github.io/ia-robotics-olympiad/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-xl bg-[#20A4F3] px-6 py-3 font-black text-[#0B1C4B] hover:bg-[#0B1C4B] hover:text-white transition-colors"
        >
          فتح منصة الأولمبياد
        </a>
        <a
          href="./"
          class="inline-flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 px-6 py-3 font-bold text-slate-900 dark:text-white hover:border-[#20A4F3] hover:text-[#20A4F3] transition-colors"
        >
          الرجوع إلى الموقع
        </a>
      </div>
    </section>
  </main>
</Layout>
