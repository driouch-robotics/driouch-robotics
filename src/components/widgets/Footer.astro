---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;

const visibleSocialLinks = socialLinks.filter(({ icon, text }) => icon || text);
const visibleSecondaryLinks = secondaryLinks.filter(({ text }) => text);
---

<footer
  dir="rtl"
  class:list={[
    { dark: theme === 'dark' },
    'relative border-t border-slate-200/80 dark:border-slate-800 not-prose overflow-hidden',
  ]}
>
  <div class="absolute inset-0 pointer-events-none bg-gradient-to-b from-slate-50/70 via-white to-white dark:from-slate-950 dark:via-slate-950 dark:to-slate-900"></div>
  <div class="absolute inset-0 pointer-events-none opacity-40 dark:opacity-20 bg-[radial-gradient(circle_at_top_right,rgba(32,164,243,0.14),transparent_28%),radial-gradient(circle_at_bottom_left,rgba(11,28,75,0.08),transparent_30%)]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 py-8 md:py-10">
      <div class="lg:col-span-4">
        <div class="h-full rounded-3xl bg-gradient-to-br from-[#0B1C4B] via-[#123979] to-[#20A4F3] text-white p-5 md:p-6 shadow-[0_20px_50px_-25px_rgba(11,28,75,0.45)] relative overflow-hidden">
          <div class="absolute -top-12 -left-12 w-32 h-32 rounded-full bg-white/10 blur-3xl"></div>
          <div class="absolute -bottom-12 -right-10 w-36 h-36 rounded-full bg-cyan-300/20 blur-3xl"></div>

          <div class="relative z-10">
            <span class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-3 py-1 text-[11px] font-bold tracking-wide mb-3">
              Future Builders • Since 2024
            </span>

            <a
              href={getHomePermalink()}
              class="block text-2xl md:text-3xl font-black tracking-tight leading-tight hover:opacity-90 transition"
            >
              {SITE?.name}
            </a>

            <p class="mt-3 text-sm md:text-[15px] leading-7 text-blue-50/85">
              نادي تربوي تقني يهدف إلى تمكين المتعلمين من مهارات الروبوتيك، البرمجة، والذكاء الاصطناعي
              عبر مشاريع تطبيقية وأنشطة تنافسية مرتبطة بالمؤسسة والمحيط المحلي.
            </p>

            <div class="mt-5 flex flex-wrap gap-3">
              <a
                href="/#about"
                class="inline-flex items-center justify-center rounded-2xl bg-white text-[#0B1C4B] px-4 py-2.5 text-sm font-black hover:bg-slate-100 transition-colors"
              >
                من نحن
              </a>

              <a
                href="/#location"
                class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white/10 px-4 py-2.5 text-sm font-bold hover:bg-white/15 transition-colors"
              >
                زيارة الموقع
              </a>
            </div>

            <div class="mt-5 space-y-2.5 text-sm">
              <div class="flex items-start gap-2 rounded-2xl border border-white/10 bg-white/10 px-3.5 py-2.5 text-blue-50/90">
                <span>📍</span>
                <span>ثانوية الوحدة الإعدادية الرائدة، امطالسة، الدريوش، جهة الشرق</span>
              </div>

              <a
                href="tel:+212677035415"
                class="flex items-center gap-2 rounded-2xl border border-white/10 bg-white/10 px-3.5 py-2.5 text-blue-50/90 hover:bg-white/15 transition-colors"
              >
                <span>📞</span>
                <span dir="ltr">+212 677 035 415</span>
              </a>

              <a
                href="mailto:mohamed.elrhaouat@gmail.com"
                class="flex items-center gap-2 rounded-2xl border border-white/10 bg-white/10 px-3.5 py-2.5 text-blue-50/90 hover:bg-white/15 transition-colors break-all"
              >
                <span>✉️</span>
                <span dir="ltr">mohamed.elrhaouat@gmail.com</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-8">
        <div class="h-full rounded-3xl border border-slate-200/80 dark:border-slate-800 bg-white/90 dark:bg-slate-900/70 backdrop-blur-sm p-5 md:p-6 shadow-sm">
          <div class="grid grid-cols-2 xl:grid-cols-4 gap-6 md:gap-8">
            {
              links.map(({ title, links }) => (
                <div>
                  <div class="text-sm font-black tracking-wide text-[#20A4F3] mb-3">{title}</div>

                  {links && Array.isArray(links) && links.length > 0 && (
                    <ul class="space-y-2.5">
                      {links.map(({ text, href, ariaLabel }) => (
                        <li>
                          <a
                            class="group inline-flex items-start gap-2 text-sm leading-6 text-slate-600 dark:text-slate-400 hover:text-[#0B1C4B] dark:hover:text-white transition-colors duration-200"
                            href={href}
                            aria-label={ariaLabel}
                          >
                            <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#20A4F3] shrink-0 group-hover:scale-125 transition-transform"></span>
                            <span set:html={text} />
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-slate-200/80 dark:border-slate-800 py-5">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="text-sm text-slate-600 dark:text-slate-400 leading-6">
          <Fragment set:html={footNote} />
        </div>

        <div class="flex flex-col gap-3 lg:items-end">
          {
            visibleSecondaryLinks?.length ? (
              <div class="flex flex-wrap gap-2">
                {visibleSecondaryLinks.map(({ text, href }) => (
                  <a
                    href={href}
                    class="inline-flex items-center rounded-full border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-3 py-1.5 text-xs md:text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-[#20A4F3] hover:border-[#20A4F3]/40 transition-colors"
                    set:html={text}
                  />
                ))}
              </div>
            ) : (
              ''
            )
          }

          {
            visibleSocialLinks?.length ? (
              <ul class="flex flex-wrap items-center gap-2">
                {visibleSocialLinks.map(({ ariaLabel, href, text, icon }) => (
                  <li>
                    {
                      href && href !== '#' ? (
                        <a
                          class="inline-flex items-center justify-center rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-2.5 text-slate-500 dark:text-slate-400 hover:text-[#20A4F3] hover:border-[#20A4F3]/40 transition-all duration-200"
                          aria-label={ariaLabel}
                          href={href}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {icon && <Icon name={icon} class="w-5 h-5" />}
                          <Fragment set:html={text} />
                        </a>
                      ) : (
                        <span
                          class="inline-flex items-center justify-center rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-2.5 text-slate-400 dark:text-slate-500 cursor-default"
                          aria-label={ariaLabel}
                          title={ariaLabel}
                        >
                          {icon && <Icon name={icon} class="w-5 h-5" />}
                          <Fragment set:html={text} />
                        </span>
                      )
                    }
                  </li>
                ))}
              </ul>
            ) : (
              ''
            )
          }
        </div>
      </div>
    </div>
  </div>
</footer>