---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink, getPermalink, trimSlash } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

interface LanguageLink {
  locale: string;
  label: string;
  shortLabel: string;
  href: string;
  active?: boolean;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  homeHref?: string;
  locale?: string;
  languageLinks?: Array<LanguageLink>;
  labels?: {
    languageSwitcher?: string;
    mainSection?: string;
    projectsLabel?: string;
    sectionProjects?: string;
  };
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  homeHref = getHomePermalink(),
  locale = 'ar',
  languageLinks = [],
  labels = {},
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;

const hasGroupedDropdown = (items?: Array<MenuLink>) =>
  Array.isArray(items) && items.some((item) => Array.isArray(item.links) && item.links.length > 0);

const getGroupCount = (item?: MenuLink) => item?.links?.length ?? 0;
const currentLanguage =
  languageLinks.find(({ active }) => active) || languageLinks.find(({ locale: itemLocale }) => itemLocale === locale);
const hasLanguageLinks = languageLinks.length > 1;
const languageSwitcherLabel = labels.languageSwitcher || 'Change language';
const mainSectionLabel = labels.mainSection || 'Main section';
const projectsLabel = labels.projectsLabel || 'projects';
const sectionProjectsLabel = labels.sectionProjects || 'Projects in this section';
const isRtl = locale === 'ar';
const menuTextAlignClass = isRtl ? 'text-right' : 'text-left';
const topDropdownPositionClass = isRtl ? 'xl:right-0' : 'xl:left-0';
const nestedDropdownPositionClass = isRtl ? 'xl:right-full xl:pr-3' : 'xl:left-full xl:pl-3';
const nestedChevronIcon = isRtl ? 'tabler:chevron-left' : 'tabler:chevron-right';
const languageDropdownPositionClass = isRtl ? 'right-0' : 'left-0';
const resolveHref = (href?: string) =>
  href && !href.startsWith('mailto:') && !href.startsWith('tel:') ? getPermalink(href) : href;
const getHeaderActionClass = (className?: string) =>
  [
    'py-2 px-3 md:px-3.5 font-semibold shadow-none text-[0.92rem] rounded-xl w-auto whitespace-nowrap',
    className,
  ]
    .filter(Boolean)
    .join(' ');
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-50/0 transition-[opacity] ease-in-out overflow-visible',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>

  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full overflow-visible',
      {
        'xl:flex xl:justify-between': position !== 'center',
      },
      {
        'xl:grid xl:grid-cols-[auto_minmax(0,1fr)_auto] xl:items-center xl:gap-4': position === 'center',
      },
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class:list={[
      { 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' },
      'flex justify-between items-center w-full xl:w-auto',
    ]}>
      <a class="flex items-center shrink-0" href={resolveHref(homeHref)}>
        <Logo />
      </a>

      <div class="flex items-center xl:hidden">
        <ToggleMenu />
      </div>
    </div>

    <nav
      class="items-center w-full xl:w-auto hidden xl:flex xl:mx-5 text-default xl:justify-self-center overflow-visible xl:min-w-0"
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col xl:flex-row xl:self-center w-full xl:w-auto text-xl xl:text-[0.9375rem] tracking-[0.01rem] font-medium xl:justify-center items-center overflow-visible"
      >
        {
          links.map(({ text, href, links }) => (
            <li
              class:list={[links?.length ? 'relative group/top mobile-submenu w-full xl:w-auto' : '', 'overflow-visible']}
              {...links?.length ? { 'data-mobile-submenu': true } : {}}
            >
              {links?.length ? (
                hasGroupedDropdown(links) ? (
                  <>
                    <button
                      type="button"
                      class="hover:text-link dark:hover:text-white px-4 py-3 flex w-full items-center justify-center gap-1 whitespace-nowrap xl:w-auto"
                      aria-expanded="false"
                      data-mobile-submenu-trigger
                    >
                      {text}
                      <Icon
                        name="tabler:chevron-down"
                        class="w-3.5 h-3.5 transition-transform duration-200 mobile-submenu-chevron"
                      />
                    </button>

                    <!-- المستوى الأول -->
                    <div
                      class:list={[
                        'mobile-menu-panel hidden w-full px-4 pb-2 xl:block xl:w-auto xl:px-0 xl:pb-0 xl:absolute xl:top-full xl:z-[80] xl:pt-2 xl:opacity-0 xl:invisible xl:translate-y-1 xl:pointer-events-none xl:transition-all xl:duration-200 xl:ease-out xl:group-hover/top:opacity-100 xl:group-hover/top:visible xl:group-hover/top:translate-y-0 xl:group-hover/top:pointer-events-auto xl:group-focus-within/top:opacity-100 xl:group-focus-within/top:visible xl:group-focus-within/top:translate-y-0 xl:group-focus-within/top:pointer-events-auto',
                        topDropdownPositionClass,
                      ]}
                    >
                      <div class="w-full xl:w-[320px] rounded-2xl border border-slate-200/80 dark:border-slate-700 bg-white/95 dark:bg-slate-900/95 shadow-lg xl:shadow-2xl backdrop-blur-xl p-3">
                        <ul class="space-y-2">
                          {links.map((group) => (
                            <li class="relative group/submenu mobile-submenu" data-mobile-submenu>
                              <button
                                type="button"
                                class="flex w-full items-center justify-between gap-4 rounded-xl px-4 py-3 bg-slate-50 dark:bg-slate-800/70 border border-slate-100 dark:border-slate-700 hover:bg-blue-50 dark:hover:bg-slate-800 transition-colors"
                                aria-expanded="false"
                                data-mobile-submenu-trigger
                              >
                                <div class:list={['min-w-0', menuTextAlignClass]}>
                                  <div class="text-[0.95rem] font-extrabold text-[#20A4F3] dark:text-[#38BDF8] leading-tight">
                                    {group.text}
                                  </div>
                                  <div class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">
                                    {mainSectionLabel} • {getGroupCount(group)} {projectsLabel}
                                  </div>
                                </div>

                                <Icon
                                  name="tabler:chevron-down"
                                  class="w-4 h-4 text-[#20A4F3] shrink-0 transition-transform duration-200 mobile-submenu-chevron xl:hidden"
                                />
                                <Icon
                                  name={nestedChevronIcon}
                                  class="hidden w-4 h-4 text-[#20A4F3] shrink-0 xl:block"
                                />
                              </button>

                              <!-- المستوى الثاني -->
                              <div
                                class:list={[
                                  'mobile-menu-panel hidden w-full pt-2 xl:block xl:w-auto xl:pt-0 xl:absolute xl:top-0 xl:z-[90] xl:opacity-0 xl:invisible xl:translate-x-1 xl:pointer-events-none xl:transition-all xl:duration-200 xl:ease-out xl:group-hover/submenu:opacity-100 xl:group-hover/submenu:visible xl:group-hover/submenu:translate-x-0 xl:group-hover/submenu:pointer-events-auto xl:group-focus-within/submenu:opacity-100 xl:group-focus-within/submenu:visible xl:group-focus-within/submenu:translate-x-0 xl:group-focus-within/submenu:pointer-events-auto',
                                  nestedDropdownPositionClass,
                                ]}
                              >
                                <div class="w-full xl:w-[360px] max-w-[calc(100vw-2rem)] rounded-2xl border border-slate-200/80 dark:border-slate-700 bg-white/95 dark:bg-slate-900/95 shadow-lg xl:shadow-2xl backdrop-blur-xl p-3">
                                  <div class:list={['mb-3 px-3 py-2 border-b border-slate-100 dark:border-slate-700', menuTextAlignClass]}>
                                    <div class="text-[0.95rem] font-extrabold text-[#20A4F3] dark:text-[#38BDF8] leading-tight">
                                      {group.text}
                                    </div>
                                    <div class="text-[11px] text-slate-500 dark:text-slate-400 mt-1">
                                      {sectionProjectsLabel}
                                    </div>
                                  </div>

                                  <ul class="space-y-1.5">
                                    {group.links?.map((project) => (
                                      <li>
                                        <a
                                          href={resolveHref(project.href)}
                                          class:list={[
                                            'group/project flex items-start justify-between gap-3 rounded-xl px-3.5 py-2.5 text-[13px] leading-6 text-slate-700 dark:text-slate-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-[#20A4F3] transition-colors duration-200',
                                            menuTextAlignClass,
                                          ]}
                                        >
                                          <span>{project.text}</span>
                                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#20A4F3]/70 transition-transform group-hover/project:scale-125"></span>
                                        </a>
                                      </li>
                                    ))}
                                  </ul>
                                </div>
                              </div>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  </>
                ) : (
                  <>
                    <button
                      type="button"
                      class="hover:text-link dark:hover:text-white px-4 py-3 flex w-full items-center justify-center gap-1 whitespace-nowrap xl:w-auto"
                      aria-expanded="false"
                      data-mobile-submenu-trigger
                    >
                      {text}
                      <Icon
                        name="tabler:chevron-down"
                        class="w-3.5 h-3.5 transition-transform duration-200 mobile-submenu-chevron"
                      />
                    </button>

                    <!-- Dropdown عادي -->
                    <div
                      class:list={[
                        'mobile-menu-panel hidden w-full px-4 pb-2 xl:block xl:w-auto xl:px-0 xl:pb-0 xl:absolute xl:top-full xl:z-[80] xl:pt-2 xl:opacity-0 xl:invisible xl:translate-y-1 xl:pointer-events-none xl:transition-all xl:duration-200 xl:ease-out xl:group-hover/top:opacity-100 xl:group-hover/top:visible xl:group-hover/top:translate-y-0 xl:group-hover/top:pointer-events-auto xl:group-focus-within/top:opacity-100 xl:group-focus-within/top:visible xl:group-focus-within/top:translate-y-0 xl:group-focus-within/top:pointer-events-auto',
                        topDropdownPositionClass,
                      ]}
                    >
                      <ul class="rounded-2xl border border-slate-200/80 dark:border-slate-700 bg-white/95 dark:bg-slate-900/95 shadow-lg xl:shadow-2xl backdrop-blur-xl min-w-[250px] p-2">
                        {links.map(({ text: text2, href: href2 }) => (
                          <li>
                            <a
                              class:list={[
                                'block rounded-xl px-4 py-2.5 text-sm text-slate-700 dark:text-slate-200 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-[#20A4F3] transition-colors duration-200',
                                menuTextAlignClass,
                                { 'aw-link-active': resolveHref(href2) === currentPath },
                              ]}
                              href={resolveHref(href2)}
                            >
                              {text2}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </>
                )
              ) : (
                <a
                  class:list={[
                    'hover:text-link dark:hover:text-white px-4 py-3 flex items-center whitespace-nowrap',
                    { 'aw-link-active': resolveHref(href) === currentPath },
                  ]}
                  href={resolveHref(href)}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden xl:self-center xl:flex items-center xl:mb-0 fixed w-full xl:w-auto xl:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 xl:p-0 xl:justify-self-end',
      ]}
    >
      <div class="items-center flex justify-end gap-2 w-full md:w-auto">
        {
          hasLanguageLinks ? (
            <div class="relative group/lang">
              <button
                type="button"
                class="inline-flex h-[42px] items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white/85 px-3 text-[0.86rem] font-black text-[#0B1C4B] shadow-none transition-all hover:border-[#20A4F3]/55 hover:bg-blue-50 dark:border-slate-700 dark:bg-slate-900/80 dark:text-[#7DD3FC] dark:hover:bg-slate-800"
                aria-label={languageSwitcherLabel}
              >
                <Icon name="tabler:world" class="h-5 w-5 text-[#20A4F3]" />
                <span>{currentLanguage?.shortLabel || locale.toUpperCase()}</span>
                <Icon name="tabler:chevron-down" class="h-3.5 w-3.5 opacity-70" />
              </button>

              <div
                class:list={[
                  'absolute top-full z-[90] pt-2 opacity-0 invisible translate-y-1 pointer-events-none transition-all duration-200 ease-out group-hover/lang:opacity-100 group-hover/lang:visible group-hover/lang:translate-y-0 group-hover/lang:pointer-events-auto group-focus-within/lang:opacity-100 group-focus-within/lang:visible group-focus-within/lang:translate-y-0 group-focus-within/lang:pointer-events-auto',
                  languageDropdownPositionClass,
                ]}
              >
                <div class="w-44 rounded-2xl border border-slate-200/80 bg-white/95 p-2 shadow-2xl backdrop-blur-xl dark:border-slate-700 dark:bg-slate-900/95">
                  <div class="px-3 pb-2 pt-1 text-[11px] font-black uppercase tracking-[0.16em] text-slate-400">
                    {languageSwitcherLabel}
                  </div>
                  <ul class="space-y-1">
                    {languageLinks.map((language) => (
                      <li>
                        <a
                          href={resolveHref(language.href)}
                          data-site-locale={language.locale}
                          class:list={[
                            'flex items-center justify-between gap-3 rounded-xl px-3 py-2 text-sm font-bold transition-colors',
                            language.active
                              ? 'bg-[#20A4F3]/12 text-[#0B1C4B] dark:text-[#7DD3FC]'
                              : 'text-slate-600 hover:bg-blue-50 hover:text-[#20A4F3] dark:text-slate-300 dark:hover:bg-slate-800',
                          ]}
                        >
                          <span>{language.label}</span>
                          <span
                            class:list={[
                              'rounded-full px-2 py-0.5 text-[11px] font-black',
                              language.active ? 'bg-[#20A4F3] text-white' : 'bg-slate-100 text-slate-500 dark:bg-slate-800',
                            ]}
                          >
                            {language.shortLabel}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ) : (
            ''
          )
        }

        {
          actions?.length ? (
            <span class="flex items-center gap-2">
              {actions.map((btnProps) => (
                <Button
                  {...btnProps}
                  class={getHeaderActionClass(btnProps.class)}
                />
              ))}
            </span>
          ) : (
            ''
          )
        }

        <div class="flex shrink-0">
          {showToggleTheme && <ToggleTheme iconClass="w-6 h-6 md:w-5 md:h-5 md:inline-block" />}
        </div>
      </div>
    </div>
  </div>
</header>

<style is:inline>
  @media (max-width: 1279px) {
    #header.expanded {
      overflow: hidden;
    }

    #header.expanded nav {
      max-height: calc(100vh - 7rem);
      overflow-y: auto;
      padding-bottom: 5.25rem;
    }

    #header .mobile-submenu-open > .mobile-menu-panel {
      display: block;
    }

    #header .mobile-submenu-open > [data-mobile-submenu-trigger] > .mobile-submenu-chevron {
      transform: rotate(180deg);
    }

    #header nav {
      align-items: stretch;
    }

    #header nav > ul {
      gap: 0.15rem;
    }
  }
</style>
