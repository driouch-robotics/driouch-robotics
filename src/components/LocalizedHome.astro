---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { ImageMetadata } from 'astro';

import teamData from '~/data/team.json';
import { localizedHome, type LocalizedHomeLocale } from '~/i18n/home';
import { getAsset, getPermalink } from '~/utils/permalinks';

export interface Props {
  locale: LocalizedHomeLocale;
}

const { locale } = Astro.props;
const content = localizedHome[locale];
const targetDate = '2026-06-08T09:00:00+01:00';
const remainingMs = Math.max(0, new Date(targetDate).getTime() - Date.now());
const initialDays = Math.floor(remainingMs / 86400000);
const initialHours = Math.floor((remainingMs % 86400000) / 3600000);
const initialMinutes = Math.floor((remainingMs % 3600000) / 60000);
const projectImageModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/*', {
  eager: true,
});

const resolveProjectImage = (imagePath = '') =>
  projectImageModules[`/${imagePath.replace(/^\//, '')}`]?.default;

const resolveHref = (href = '') =>
  href.startsWith('http://') || href.startsWith('https://') || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('#')
    ? href
    : getPermalink(href);

const featuredStudents = teamData.students.slice(0, 6);

const faq =
  locale === 'fr'
    ? [
        {
          question: 'Le site arabe reste-t-il la version principale ?',
          answer:
            'Oui. La version arabe reste la référence du club, tandis que les versions française et anglaise rendent le contenu accessible à un public plus large.',
        },
        {
          question: 'Les fiches techniques des projets sont-elles déjà traduites ?',
          answer:
            'Cette première phase traduit l’accueil, la navigation et les informations générales. Les fiches détaillées peuvent être localisées dans une phase suivante.',
        },
        {
          question: 'Comment suivre les activités du club ?',
          answer:
            'Vous pouvez suivre le club via Instagram, GitHub et les pages dédiées aux événements comme IA Day.',
        },
      ]
    : [
        {
          question: 'Does Arabic remain the main version of the website?',
          answer:
            'Yes. Arabic remains the club’s reference version, while French and English make the content accessible to a wider audience.',
        },
        {
          question: 'Are project technical sheets translated already?',
          answer:
            'This first phase translates the homepage, navigation and general information. Detailed project sheets can be localized in the next phase.',
        },
        {
          question: 'How can we follow club activities?',
          answer:
            'You can follow the club through Instagram, GitHub and dedicated event pages such as IA Day.',
        },
      ];
---

<div dir={content.dir} class="overflow-hidden bg-white text-slate-900 dark:bg-slate-950 dark:text-white">
  <style is:global>
    @keyframes localized-countdown-pulse {
      0%,
      100% {
        transform: translateY(0) scale(1);
        box-shadow: 0 0 0 0 rgba(32, 164, 243, 0.28);
      }

      50% {
        transform: translateY(-1px) scale(1.03);
        box-shadow: 0 0 0 10px rgba(32, 164, 243, 0);
      }
    }

    .localized-countdown-icon {
      animation: localized-countdown-pulse 2.8s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
      .localized-countdown-icon {
        animation: none;
      }
    }
  </style>

  <section class="relative px-4 pb-14 pt-12 sm:px-6 lg:px-8 lg:pb-16 lg:pt-16">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(32,164,243,0.13),transparent_34%),linear-gradient(180deg,rgba(248,250,252,0.94),rgba(255,255,255,1))] dark:bg-[radial-gradient(circle_at_top,rgba(32,164,243,0.18),transparent_32%),linear-gradient(180deg,rgba(2,6,23,1),rgba(15,23,42,1))]"></div>
    <div class="absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-t from-white dark:from-slate-950"></div>

    <div class="mx-auto max-w-6xl text-center">
      <span class="inline-flex items-center justify-center rounded-full border border-[#20A4F3]/25 bg-[#20A4F3]/10 px-4 py-2 text-sm font-black text-[#0B1C4B] dark:text-[#7DD3FC]">
        <Icon name="tabler:sparkles" class="me-2 h-4 w-4 text-[#20A4F3]" />
        {content.hero.badge}
      </span>

      <h1 class="mx-auto mt-7 max-w-5xl text-4xl font-black leading-tight tracking-normal text-slate-950 dark:text-white md:text-6xl">
        {content.hero.title}
        <span class="block bg-gradient-to-r from-[#20A4F3] via-[#0B1C4B] to-[#20A4F3] bg-clip-text text-transparent dark:from-[#7DD3FC] dark:via-white dark:to-[#20A4F3]">
          {content.hero.accent}
        </span>
      </h1>

      <p class="mx-auto mt-5 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300">
        {content.hero.subtitle}
      </p>

      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a
          href={content.hero.primaryHref}
          class="inline-flex items-center justify-center gap-2 rounded-2xl bg-[#0B1C4B] px-5 py-3 text-base font-black text-white shadow-[0_18px_45px_-28px_rgba(11,28,75,0.8)] transition-all hover:-translate-y-0.5 hover:bg-[#20A4F3] hover:text-[#0B1C4B] dark:bg-[#20A4F3] dark:text-[#0B1C4B]"
        >
          <Icon name="tabler:rocket" class="h-5 w-5" />
          {content.hero.primaryCta}
        </a>
        <a
          href={content.hero.secondaryHref}
          class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 bg-white/80 px-5 py-3 text-base font-black text-[#0B1C4B] transition-all hover:-translate-y-0.5 hover:border-[#20A4F3] hover:text-[#20A4F3] dark:border-slate-700 dark:bg-slate-900/80 dark:text-white"
        >
          <Icon name="tabler:users-group" class="h-5 w-5" />
          {content.hero.secondaryCta}
        </a>
      </div>

      <div
        data-localized-countdown
        data-target={targetDate}
        data-finished-label={content.countdown.finishedLabel}
        class="mx-auto mt-8 flex max-w-4xl flex-col gap-4 rounded-3xl border border-[#20A4F3]/25 bg-white/85 p-4 text-start shadow-[0_22px_70px_-46px_rgba(11,28,75,0.7)] backdrop-blur-md dark:bg-slate-900/85 md:flex-row md:items-center md:justify-between"
        id="iaday-2026"
      >
        <div class="flex items-center gap-4">
          <span class="localized-countdown-icon inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-[#20A4F3]/30 bg-[#20A4F3]/10 text-[#20A4F3]">
            <Icon name="tabler:calendar-time" class="h-8 w-8" />
          </span>
          <span>
            <span class="block text-xs font-black uppercase tracking-[0.18em] text-[#20A4F3]">
              {content.countdown.kicker}
            </span>
            <span class="mt-1 block text-lg font-black leading-7 text-slate-950 dark:text-white">
              {content.countdown.title}
            </span>
            <span data-countdown-label class="mt-1 block text-sm font-semibold text-slate-500 dark:text-slate-400">
              {content.countdown.dateLabel}
            </span>
          </span>
        </div>

        <div class="grid grid-cols-3 gap-2 text-center md:min-w-[290px]">
          <span class="rounded-2xl bg-[#0B1C4B] px-4 py-3 text-white dark:bg-white/10">
            <span data-countdown-days class="block text-3xl font-black leading-none tabular-nums" dir="ltr">
              {initialDays}
            </span>
            <span class="mt-2 block text-[11px] font-bold text-blue-100/75">{content.countdown.units.days}</span>
          </span>
          <span class="rounded-2xl bg-[#0B1C4B] px-4 py-3 text-white dark:bg-white/10">
            <span data-countdown-hours class="block text-3xl font-black leading-none tabular-nums" dir="ltr">
              {String(initialHours).padStart(2, '0')}
            </span>
            <span class="mt-2 block text-[11px] font-bold text-blue-100/75">{content.countdown.units.hours}</span>
          </span>
          <span class="rounded-2xl bg-[#0B1C4B] px-4 py-3 text-white dark:bg-white/10">
            <span data-countdown-minutes class="block text-3xl font-black leading-none tabular-nums" dir="ltr">
              {String(initialMinutes).padStart(2, '0')}
            </span>
            <span class="mt-2 block text-[11px] font-bold text-blue-100/75">{content.countdown.units.minutes}</span>
          </span>
        </div>
      </div>

      <div class="mx-auto mt-8 grid max-w-4xl grid-cols-2 gap-3 md:grid-cols-4">
        {
          content.stats.map((stat) => (
            <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/80">
              <div class="text-2xl font-black text-[#0B1C4B] dark:text-[#7DD3FC]">{stat.value}</div>
              <div class="mt-1 text-xs font-semibold leading-5 text-slate-500 dark:text-slate-400">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="about" class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <span class="text-sm font-black uppercase tracking-[0.18em] text-[#20A4F3]">{content.about.kicker}</span>
        <h2 class="mt-3 text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">
          {content.about.title}
        </h2>
        <div class="mt-5 space-y-4 text-base leading-8 text-slate-600 dark:text-slate-300">
          {content.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="mt-6 flex flex-wrap gap-2 text-sm font-bold text-slate-500 dark:text-slate-400">
          <span class="rounded-full border border-slate-200 px-3 py-1 dark:border-slate-800">{content.hero.institution}</span>
          <span class="rounded-full border border-slate-200 px-3 py-1 dark:border-slate-800">{content.hero.supervisor}</span>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {
          content.about.cards.map((card) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:-translate-y-1 hover:border-[#20A4F3]/50 hover:shadow-xl dark:border-slate-800 dark:bg-slate-900">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#20A4F3]/10 text-[#20A4F3]">
                <Icon name={card.icon} class="h-7 w-7" />
              </span>
              <h3 class="mt-4 text-lg font-black text-slate-950 dark:text-white">{card.title}</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-400">{card.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="projects" class="bg-slate-50 px-4 py-14 dark:bg-slate-900/45 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <span class="text-sm font-black uppercase tracking-[0.18em] text-[#20A4F3]">{content.projects.kicker}</span>
        <h2 class="mt-3 text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">
          {content.projects.title}
        </h2>
        <p class="mt-4 text-base leading-8 text-slate-600 dark:text-slate-300">{content.projects.subtitle}</p>
      </div>

      <div class="mt-9 space-y-10">
        {
          content.projects.categories.map((category) => (
            <div>
              <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                <div>
                  <h3 class="text-2xl font-black text-[#0B1C4B] dark:text-[#7DD3FC]">{category.title}</h3>
                  <p class="mt-1 text-sm leading-7 text-slate-500 dark:text-slate-400">{category.description}</p>
                </div>
              </div>

              <div class="mt-5 grid gap-5 md:grid-cols-3">
                {category.items.map((project) => {
                  const projectImage = resolveProjectImage(project.image);

                  return (
                    <article class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:border-[#20A4F3]/50 hover:shadow-2xl dark:border-slate-800 dark:bg-slate-950">
                      <a href={resolveHref(project.href)} class="block">
                        <div class="aspect-[16/10] overflow-hidden bg-slate-100 dark:bg-slate-900">
                          {projectImage ? (
                            <Image
                              src={projectImage}
                              alt={project.title}
                              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                            />
                          ) : (
                            <div class="flex h-full items-center justify-center text-slate-400">
                              <Icon name="tabler:photo" class="h-10 w-10" />
                            </div>
                          )}
                        </div>
                        <div class="p-5">
                          <div class="flex flex-wrap gap-2">
                            {project.tags.map((tag) => (
                              <span class="rounded-full bg-[#20A4F3]/10 px-2.5 py-1 text-[11px] font-black text-[#0B1C4B] dark:text-[#7DD3FC]">
                                {tag}
                              </span>
                            ))}
                          </div>
                          <h4 class="mt-4 text-xl font-black leading-7 text-slate-950 dark:text-white">{project.title}</h4>
                          <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-400">{project.description}</p>
                          <span class="mt-4 inline-flex items-center gap-2 text-sm font-black text-[#20A4F3]">
                            {content.projects.viewProject}
                            <Icon name="tabler:arrow-right" class="h-4 w-4 rtl:rotate-180" />
                          </span>
                        </div>
                      </a>
                    </article>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <span class="text-sm font-black uppercase tracking-[0.18em] text-[#20A4F3]">{content.iaDay.kicker}</span>
        <h2 class="mt-3 text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">
          {content.iaDay.title}
        </h2>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <img
            src={getAsset('assets/events/ia-day-edition-1/31.jpg')}
            alt={content.iaDay.edition1.title}
            class="h-64 w-full object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="text-2xl font-black text-slate-950 dark:text-white">{content.iaDay.edition1.title}</h3>
            <p class="mt-3 text-base leading-8 text-slate-600 dark:text-slate-300">{content.iaDay.edition1.description}</p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a href={resolveHref(content.iaDay.edition1.href)} class="inline-flex items-center gap-2 rounded-xl bg-[#0B1C4B] px-4 py-2.5 text-sm font-black text-white transition-colors hover:bg-[#20A4F3] hover:text-[#0B1C4B]">
                <Icon name="tabler:photo-spark" class="h-5 w-5" />
                {content.iaDay.edition1.cta}
              </a>
              <a href={content.iaDay.edition1.reportHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-black text-slate-700 transition-colors hover:border-[#20A4F3] hover:text-[#20A4F3] dark:border-slate-700 dark:text-slate-200">
                <Icon name="tabler:brand-facebook" class="h-5 w-5" />
                {content.iaDay.edition1.reportCta}
              </a>
            </div>
          </div>
        </article>

        <article class="flex min-h-full flex-col justify-between rounded-3xl border border-[#20A4F3]/25 bg-gradient-to-br from-[#0B1C4B] via-[#123979] to-[#20A4F3] p-6 text-white shadow-[0_24px_70px_-45px_rgba(11,28,75,0.8)]">
          <div>
            <span class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-black">
              {content.countdown.targetLabel}
            </span>
            <h3 class="mt-5 text-3xl font-black leading-tight">{content.iaDay.edition2.title}</h3>
            <p class="mt-4 text-base leading-8 text-blue-50/85">{content.iaDay.edition2.description}</p>
          </div>
          <a href={content.iaDay.edition2.href} class="mt-8 inline-flex w-fit items-center gap-2 rounded-xl bg-white px-4 py-2.5 text-sm font-black text-[#0B1C4B] transition-colors hover:bg-blue-50">
            <Icon name="tabler:calendar-time" class="h-5 w-5" />
            {content.iaDay.edition2.cta}
          </a>
        </article>
      </div>
    </div>
  </section>

  <section id="awareness" class="bg-slate-50 px-4 py-14 dark:bg-slate-900/45 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <span class="text-sm font-black uppercase tracking-[0.18em] text-[#20A4F3]">{content.awareness.kicker}</span>
        <h2 class="mt-3 text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">
          {content.awareness.title}
        </h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {
          content.awareness.cards.map((card) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#20A4F3]/10 text-[#20A4F3]">
                <Icon name={card.icon} class="h-7 w-7" />
              </span>
              <h3 class="mt-4 text-xl font-black text-slate-950 dark:text-white">{card.title}</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-400">{card.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="team" class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <span class="text-sm font-black uppercase tracking-[0.18em] text-[#20A4F3]">{content.team.kicker}</span>
        <h2 class="mt-3 text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">
          {content.team.title}
        </h2>
        <p class="mt-4 text-base leading-8 text-slate-600 dark:text-slate-300">{content.team.subtitle}</p>
      </div>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredStudents.map((student) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <div class="flex items-center gap-4">
                <img
                  src={getAsset(student.profile_pic)}
                  alt={student.name[locale] || student.name.en}
                  class="h-16 w-16 rounded-2xl object-cover ring-2 ring-[#20A4F3]/20"
                  loading="lazy"
                />
                <div>
                  <h3 class="text-lg font-black text-slate-950 dark:text-white">{student.name[locale] || student.name.en}</h3>
                  <p class="mt-1 text-sm font-semibold text-[#20A4F3]">{student.role[locale] || student.role.en}</p>
                </div>
              </div>
              <p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-400">{student.description[locale] || student.description.en}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="contact" class="bg-slate-50 px-4 py-14 dark:bg-slate-900/45 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <span class="text-sm font-black uppercase tracking-[0.18em] text-[#20A4F3]">{content.contact.kicker}</span>
        <h2 class="mt-3 text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">
          {content.contact.title}
        </h2>
        <p class="mt-4 text-base leading-8 text-slate-600 dark:text-slate-300">{content.contact.description}</p>
      </div>

      <div id="location" class="grid gap-4 sm:grid-cols-2">
        <a href="mailto:mohamed.elrhaouat@gmail.com" class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-[#20A4F3]/50 dark:border-slate-800 dark:bg-slate-950">
          <Icon name="tabler:mail" class="h-8 w-8 text-[#20A4F3]" />
          <div class="mt-3 text-sm font-bold text-slate-500">Email</div>
          <div class="mt-1 break-all text-lg font-black text-slate-950 dark:text-white">{content.contact.email}</div>
        </a>
        <a href="tel:+212677035415" class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-[#20A4F3]/50 dark:border-slate-800 dark:bg-slate-950">
          <Icon name="tabler:phone-call" class="h-8 w-8 text-[#20A4F3]" />
          <div class="mt-3 text-sm font-bold text-slate-500">Phone</div>
          <div class="mt-1 text-lg font-black text-slate-950 dark:text-white" dir="ltr">{content.contact.phone}</div>
        </a>
        <a href="https://github.com/driouch-robotics" target="_blank" rel="noopener noreferrer" class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-[#20A4F3]/50 dark:border-slate-800 dark:bg-slate-950">
          <Icon name="tabler:brand-github" class="h-8 w-8 text-[#20A4F3]" />
          <div class="mt-3 text-lg font-black text-slate-950 dark:text-white">{content.contact.github}</div>
        </a>
        <a href="https://www.instagram.com/ia.robotics.club/" target="_blank" rel="noopener noreferrer" class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-[#20A4F3]/50 dark:border-slate-800 dark:bg-slate-950">
          <Icon name="tabler:brand-instagram" class="h-8 w-8 text-[#20A4F3]" />
          <div class="mt-3 text-lg font-black text-slate-950 dark:text-white">{content.contact.instagram}</div>
        </a>
        <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-950 sm:col-span-2">
          <Icon name="tabler:map-pin-filled" class="h-8 w-8 text-[#20A4F3]" />
          <div class="mt-3 text-lg font-black text-slate-950 dark:text-white">{content.contact.location}</div>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-4">
        {
          faq.map((item) => (
            <details class="group rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-black text-slate-950 dark:text-white">
                {item.question}
                <Icon name="tabler:plus" class="h-5 w-5 text-[#20A4F3] transition-transform group-open:rotate-45" />
              </summary>
              <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-400">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <script data-astro-rerun>
    const setupLocalizedCountdowns = () => {
      const cards = document.querySelectorAll('[data-localized-countdown]');
      const dayMs = 86400000;
      const hourMs = 3600000;
      const minuteMs = 60000;
      const formatTwo = (value) => String(Math.max(0, value)).padStart(2, '0');

      cards.forEach((card) => {
        if (card.dataset.countdownReady === 'true') return;

        const targetTime = new Date(card.dataset.target || '').getTime();
        if (Number.isNaN(targetTime)) return;

        card.dataset.countdownReady = 'true';

        const dayValue = card.querySelector('[data-countdown-days]');
        const hourValue = card.querySelector('[data-countdown-hours]');
        const minuteValue = card.querySelector('[data-countdown-minutes]');
        const label = card.querySelector('[data-countdown-label]');
        const finishedLabel = card.dataset.finishedLabel || '';

        const updateCountdown = () => {
          const remaining = Math.max(0, targetTime - Date.now());
          const days = remaining > 0 ? Math.floor(remaining / dayMs) : 0;
          const hours = Math.floor((remaining % dayMs) / hourMs);
          const minutes = Math.floor((remaining % hourMs) / minuteMs);

          if (dayValue) dayValue.textContent = String(days);
          if (hourValue) hourValue.textContent = formatTwo(hours);
          if (minuteValue) minuteValue.textContent = formatTwo(minutes);
          if (remaining === 0 && label && finishedLabel) label.textContent = finishedLabel;
        };

        updateCountdown();
        window.setInterval(updateCountdown, minuteMs);
      });
    };

    setupLocalizedCountdowns();
    document.addEventListener('astro:page-load', setupLocalizedCountdowns);
  </script>
</div>
