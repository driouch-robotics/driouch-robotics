---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

import PageLayout from '~/layouts/PageLayout.astro';
import teamData from '~/data/team.json';
import { getProjectLabels, getProjectLocaleText } from '~/i18n/projects';
import type { Locale } from '~/i18n/config';
import { getAsset } from '~/utils/permalinks';

export interface Props {
  entry: CollectionEntry<'projects'>;
  locale?: Locale;
}

const { entry, locale = 'ar' } = Astro.props;
const { Content } = await entry.render();
const labels = getProjectLabels(locale);
const localized = getProjectLocaleText(entry.slug, locale, {
  title: entry.data.title,
  category: entry.data.category,
  supervisor: entry.data.supervisor || '',
  institution: entry.data.institution || '',
  domain: entry.data.domain || '',
});

const projectTeam = entry.data.team
  ? teamData.students.filter((student) => entry.data.team?.includes(student.id))
  : [];

const galleryImages = entry.data.images || (entry.data.coverImage ? [entry.data.coverImage] : []);

const projectImageModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/*', {
  eager: true,
});

const resolveProjectImage = (imagePath = '') =>
  projectImageModules[`/${imagePath.replace(/^\//, '')}`]?.default;

const metadata = {
  title: `${localized.title} | IA & Robotics Club`,
};
---

<PageLayout metadata={metadata}>
  <article class="container mx-auto px-4 sm:px-6 py-12 md:py-20 max-w-4xl" dir={locale === 'ar' ? 'rtl' : 'ltr'}>
    <header class="mb-12 text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-blue-50 text-[#20A4F3] text-sm font-bold tracking-wider mb-4 border border-blue-100">
        {localized.category}
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
        {localized.title}
      </h1>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-gray-600 dark:text-slate-400 font-medium">
        {localized.institution && <span>{localized.institution}</span>}
        {localized.supervisor && <span>{labels.supervisorPrefix} {localized.supervisor}</span>}
        {localized.domain && <span>{localized.domain}</span>}
      </div>
    </header>

    {
      galleryImages.length > 0 && (
        <div class="diaporama-container relative w-full h-64 md:h-96 rounded-2xl overflow-hidden mb-12 shadow-lg border border-gray-100 dark:border-slate-800 bg-slate-100 dark:bg-slate-800">
          {galleryImages.map((img, index) => {
            const projectImage = resolveProjectImage(img);
            const alt = `${labels.imageAltPrefix} ${index + 1} ${labels.imageAltMiddle} ${localized.title}`;

            return projectImage ? (
              <Image
                src={projectImage}
                alt={alt}
                class={`slide-img absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            ) : (
              <img
                src={getAsset(img.replace(/^\//, ''))}
                alt={alt}
                class={`slide-img absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                onerror="this.style.display='none';"
              />
            );
          })}
        </div>
      )
    }

    <div
      class="prose prose-lg prose-blue dark:prose-invert max-w-none prose-headings:text-[#0B1C4B] dark:prose-headings:text-[#20A4F3] prose-headings:font-bold prose-p:text-gray-700 dark:prose-p:text-slate-300 prose-p:leading-relaxed prose-li:text-gray-700 dark:prose-li:text-slate-300"
    >
      <Content />
    </div>

    {
      projectTeam.length > 0 && (
        <div class="mt-16 pt-10 border-t border-gray-200 dark:border-slate-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 text-center">
            {labels.teamTitle}
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            {projectTeam.map((student) => {
              const studentName = student.name[locale] || student.name.ar;
              const studentRole = student.role[locale] || student.role.ar;

              return (
                <div class="flex flex-col p-5 bg-white dark:bg-slate-800 rounded-xl border border-gray-100 dark:border-slate-700 hover:border-[#20A4F3] transition-all hover:shadow-md relative group">
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full bg-blue-100 dark:bg-slate-700 flex items-center justify-center text-xl font-bold text-[#0B1C4B] dark:text-[#20A4F3] shrink-0 border-2 border-white dark:border-slate-600 shadow-sm overflow-hidden relative">
                      <img
                        src={getAsset(student.profile_pic)}
                        alt={studentName}
                        class="w-full h-full object-cover z-10"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                      />
                      <span class="absolute inset-0 flex items-center justify-center hidden z-0">
                        {studentName.charAt(0)}
                      </span>
                    </div>

                    <div>
                      <h4 class="font-bold text-base text-gray-900 dark:text-white">{studentName}</h4>
                      <p class="text-xs text-[#20A4F3] font-semibold">{studentRole}</p>
                    </div>
                  </div>

                  <a
                    href={`https://elrhaouat.github.io/robotics-badges/badge.html?id=${student.id}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-auto w-full py-2 px-3 text-xs font-bold text-center text-[#0B1C4B] dark:text-white bg-blue-50 dark:bg-slate-700/50 border border-blue-100 dark:border-slate-600 rounded-lg hover:bg-[#20A4F3] hover:text-white hover:border-transparent transition-colors duration-300 flex items-center justify-center gap-2"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                      <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
                      <path d="M14 15h3"></path>
                      <path d="M10 13a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
                      <path d="M12 11v-1"></path>
                    </svg>
                    {labels.badge}
                  </a>
                </div>
              );
            })}
          </div>
        </div>
      )
    }
  </article>

  <script is:inline data-astro-rerun>
    (() => {
      const controllerKey = '__projectDiaporamaController';
      const existingController = window[controllerKey];

      if (existingController) {
        existingController.init();
        return;
      }

      const intervals = new Set();

      const stop = () => {
        intervals.forEach((intervalId) => window.clearInterval(intervalId));
        intervals.clear();
      };

      const showSlide = (slides, currentIndex, nextIndex) => {
        slides[currentIndex]?.classList.remove('opacity-100');
        slides[currentIndex]?.classList.add('opacity-0');
        slides[nextIndex]?.classList.remove('opacity-0');
        slides[nextIndex]?.classList.add('opacity-100');
      };

      const init = () => {
        stop();

        document.querySelectorAll('.diaporama-container').forEach((slider) => {
          const slides = Array.from(slider.querySelectorAll('.slide-img'));
          if (slides.length <= 1) return;

          slides.forEach((slide, index) => {
            slide.classList.toggle('opacity-100', index === 0);
            slide.classList.toggle('opacity-0', index !== 0);
          });

          let currentIdx = 0;
          const intervalId = window.setInterval(() => {
            const nextIdx = (currentIdx + 1) % slides.length;
            showSlide(slides, currentIdx, nextIdx);
            currentIdx = nextIdx;
          }, 3500);

          intervals.add(intervalId);
        });
      };

      window[controllerKey] = { init, stop };

      document.addEventListener('astro:page-load', init);
      document.addEventListener('astro:before-swap', stop);

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
      } else {
        init();
      }
    })();
  </script>
</PageLayout>
